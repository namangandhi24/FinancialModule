generator client {
  provider = "prisma-client-js"
}

// Seed: pnpm db:seed

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AccountType {
  SAVINGS
  CURRENT
  CREDIT_CARD
  CASH
  INVESTMENT
  LOAN
}

enum AccountStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
  INVESTMENT
  LOAN_PAYMENT
}

enum CurrencyCode {
  USD
  INR
  EUR
  GBP
  JPY
  CAD
  AUD
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_RESET
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum StatementImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum InvestmentType {
  MUTUAL_FUND
  STOCK
  ETF
  GOLD
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            UserRole     @default(USER)
  defaultCurrency CurrencyCode @default(USD)
  totpSecret      String?
  totpEnabled     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  refreshTokens   RefreshToken[]
  accounts        Account[]
  transactions    Transaction[]
  categories      Category[]
  auditLogs       AuditLog[]
  budgets         Budget[]
  goals           Goal[]
  investments     Investment[]
  notifications   Notification[]
  forecasts       Forecast[]
  insights        Insight[]
  statementImports StatementImport[]
  aiConversations AIConversation[]
  categorizationRules CategorizationRule[]
  netWorthSnapshots NetWorthSnapshot[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Account {
  id          String        @id @default(uuid())
  userId      String
  name        String
  type        AccountType
  institution String?
  balance     Decimal       @db.Decimal(18, 2)
  currency    CurrencyCode
  status      AccountStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name, type])
  @@index([userId, type])
  @@map("accounts")
}

model Category {
  id        String   @id @default(uuid())
  userId    String?
  name      String
  slug      String
  icon      String?
  color     String?
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  categorizationRules CategorizationRule[]

  @@unique([userId, slug])
  @@map("categories")
}

model Merchant {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  transactions Transaction[]

  @@map("merchants")
}

model Transaction {
  id              String          @id @default(uuid())
  userId          String
  accountId       String
  amount          Decimal         @db.Decimal(18, 2)
  date            DateTime
  merchantId      String?
  merchantName    String?
  categoryId      String?
  notes           String?
  type            TransactionType
  tags            String[]        @default([])
  transferGroupId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@index([userId, date(sort: Desc)])
  @@index([userId, accountId])
  @@index([userId, categoryId])
  @@index([transferGroupId])
  @@map("transactions")
}

model AuditLog {
  id            String      @id @default(uuid())
  userId        String
  action        AuditAction
  entityType    String
  entityId      String?
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Budget {
  id         String   @id @default(uuid())
  userId     String
  categoryId String
  amount     Decimal  @db.Decimal(18, 2)
  month      Int
  year       Int
  currency   CurrencyCode
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@map("budgets")
}

model Goal {
  id                   String       @id @default(uuid())
  userId               String
  name                 String
  targetAmount         Decimal      @db.Decimal(18, 2)
  currentSavings       Decimal      @db.Decimal(18, 2) @default(0)
  monthlyContribution  Decimal      @db.Decimal(18, 2) @default(0)
  targetDate           DateTime
  currency             CurrencyCode
  status               GoalStatus   @default(ACTIVE)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("goals")
}

model Investment {
  id        String         @id @default(uuid())
  userId    String
  name      String
  type      InvestmentType
  symbol    String?
  currency  CurrencyCode
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings Holding[]

  @@index([userId])
  @@map("investments")
}

model Holding {
  id           String   @id @default(uuid())
  investmentId String
  quantity     Decimal  @db.Decimal(18, 6)
  averageCost  Decimal  @db.Decimal(18, 2)
  currentPrice Decimal  @db.Decimal(18, 2) @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@map("holdings")
}

model Notification {
  id        String              @id @default(uuid())
  userId    String
  title     String
  message   String
  channel   NotificationChannel @default(IN_APP)
  read      Boolean             @default(false)
  metadata  Json?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}

model Forecast {
  id        String   @id @default(uuid())
  userId    String
  horizon   Int
  data      Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, horizon])
  @@map("forecasts")
}

model Insight {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("insights")
}

model StatementImport {
  id           String                @id @default(uuid())
  userId       String
  accountId    String?
  fileName     String
  fileType     String
  fileUrl      String?
  status       StatementImportStatus @default(PENDING)
  errorMessage String?
  recordCount  Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("statement_imports")
}

model NetWorthSnapshot {
  id               String   @id @default(uuid())
  userId           String
  date             DateTime @db.Date
  assetsTotal      Decimal  @db.Decimal(18, 2)
  liabilitiesTotal Decimal  @db.Decimal(18, 2)
  netWorth         Decimal  @db.Decimal(18, 2)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("net_worth_snapshots")
}

model CategorizationRule {
  id         String   @id @default(uuid())
  userId     String?
  pattern    String
  categoryId String
  isSystem   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("categorization_rules")
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("ai_conversations")
}

model AIMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String
  toolCalls      Json?
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}
