# Database
DATABASE_URL="postgresql://finpilot:finpilot@localhost:5432/finpilot?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Encryption (AES-256-GCM for 2FA secrets at rest)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"

# App
API_PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
# Comma-separated extra allowed browser origins (production)
ALLOWED_ORIGINS=""
NODE_ENV="development"

# OpenAI (production)
OPENAI_API_KEY=""

# Ollama (local dev)
OLLAMA_BASE_URL="http://localhost:11434"

# Azure Blob Storage (Phase 2)
AZURE_STORAGE_CONNECTION_STRING=""

# Email (Phase 5)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="FinPilot AI <noreply@finpilot.ai>"

# AI models
OPENAI_MODEL="gpt-4o-mini"
OLLAMA_MODEL="llama3.2"
